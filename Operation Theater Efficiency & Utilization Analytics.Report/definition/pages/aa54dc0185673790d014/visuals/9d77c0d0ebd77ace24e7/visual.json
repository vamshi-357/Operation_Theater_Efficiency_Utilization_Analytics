                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "ordered"
              },
              {
                "textRuns": [
                  {
                    "value": "To calculate and track KPIs including OT Utilization Rate, Case Cancellation Rate, Turnover Time, First-Case Start Time (FCST) compliance, and Average Surgery Duration.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "ordered"
              },
              {
                "textRuns": [
