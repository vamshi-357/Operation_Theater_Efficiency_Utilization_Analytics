          "properties": {
            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "                                             Description of the project :",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt",
                      "color": "#09124f"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "This project simulates a hospital's operational data environment and uses Microsoft Power BI to create an end-to-end analytics solution focused on Operation Theater management. The dataset encompasses records of surgeries performed across multiple OT rooms over a period of one year, including fields such as surgery type, surgeon name, scheduled vs. actual start times, duration, room assigned, anesthesia type, patient category, and cancellation reasons.",
                    "textStyle": {
                      "fontSize": "12pt",
                      "color": "black"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "The Power BI solution consists of the following interconnected components:",
                    "textStyle": {
                      "fontSize": "12pt",
                      "color": "black"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Data Source Layer: A structured Excel/CSV dataset mimicking real hospital OT logs.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Data Transformation Layer: Power Query is used to clean, reshape, and load data.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Data Model Layer: A star-schema relational model linking fact and dimension tables.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Calculation Layer: DAX formulas for all KPIs, time intelligence, and custom metrics.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "Visualization Layer: Multiple report pages with charts, KPI cards, slicers, and maps.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ],
                "listType": "bullet"
              },
              {
                "textRuns": [
                  {
                    "value": "\t\t\t\t\t\t\t\t\t\t\t\t\t  ",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": "Key Modules & Features:",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Executive Summary",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": "\t",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Provides a high-level snapshot of overall OT performance with KPI cards for Utilization Rate, Total Cases, Cancellation Rate, and FCST Compliance. Features a monthly trend line chart and department-wise case volume bar chart to give administrators a quick pulse on OT health.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "OT Room Utilization\t",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Analyzes each OT room's efficiency with utilization percentage bars, average daily case count, and a time-of-day heat map highlighting peak usage hours. Helps OT coordinators identify underbooked rooms and schedule optimization opportunities.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Surgeon Performance Analytics",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": "\t",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Displays surgeon-wise breakdowns of case volume, average start delay, and FCST compliance using bar and scatter charts. Enables department heads to benchmark individual surgeon performance and identify patterns of recurring late starts.",
                    "textStyle": {
                      "fontSize": "12pt"
                    }
                  }
                ]
              }
            ]
          }
        }
      ]
